<div class="container">
  <div class="header">
    <div class="brand">Learn Cards</div>
    <div class="nav">
      <%= link_to "履歴", histories_path, class: "btn btn-ghost" %>
    </div>
  </div>

  <div class="card">
    <% if user_signed_in? %>
        <h1 class="h1">今日のテーマ</h1>

        <% if @topic %>
            <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
                <strong><%= @topic.title %></strong>
                <% badge_class = @topic.topic_type == "implementation" ? "badge badge-impl" : "badge badge-concept" %>
                <span class="<%= badge_class %>">タイプ：<%= @topic.topic_type_label %></span>
            </div>
            <p class="meta">カテゴリ：Web基礎</p>

            <div class="hr"></div>

            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                <%= link_to "詳細を見る", topic_path(@topic), class: "btn btn-primary" %>
                <%= link_to "別のテーマを見る", root_path, class: "btn" %>
            </div>
        <% else %>
        <p>テーマがありません。seedを確認してください。</p>
        <% end %>
    <% else %>
      <h1 class="h1">学習テーマアプリ</h1>
      <p class="meta">ログインすると、学習テーマの閲覧・履歴管理ができます。</p>

      <div class="hr"></div>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <%= link_to "ログイン", new_user_session_path, class: "btn btn-primary" %>
        <%= link_to "サインアップ", new_user_registration_path, class: "btn" %>
      </div>
    <% end %>
  </div>
</div>
